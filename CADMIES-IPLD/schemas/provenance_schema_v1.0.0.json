{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProvenanceRecord",
  "description": "Separates authorship/timestamp from scientific content for deterministic CIDs",
  "version": "1.0.0",
  "type": "object",
  "required": ["concept_cid", "timestamp", "author", "record_type"],
  "properties": {
    "concept_cid": {
      "type": "string",
      "pattern": "^bafy",
      "description": "CID of the scientific concept this record references"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of this record"
    },
    "author": {
      "type": "string",
      "description": "Author identifier (email, public key, or human ID)"
    },
    "record_type": {
      "type": "string",
      "enum": ["creation", "verification", "supersession", "comment"],
      "description": "Type of provenance record"
    },
    "signature": {
      "type": "string",
      "description": "Optional cryptographic signature of the record"
    },
    "supersedes": {
      "type": "string",
      "pattern": "^bafy",
      "description": "For supersession records: CID of the concept being replaced"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "For verification records: confidence score (0-1)"
    },
    "comment": {
      "type": "string",
      "description": "Optional human-readable note"
    }
  }
}
