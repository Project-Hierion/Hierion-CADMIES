# ===========================================
# CADMIES .gitignore
# ===========================================
# Blocks sensitive files, system paths, and credentials.
# Allows source code, documentation, and public data.
# Adheres to GitHub community standards.

# ========================
# 1. BLOCK EVERYTHING FIRST
# ========================
*

# ========================
# 2. ALLOW PROJECT FILES
# ========================
!*.py
!*.md
!*.json
!*.sh
!*.html
!*.css
!*.js
!*.xml
!*.car
!*.txt
!*.yml
!*.yaml
!*.toml
!*.cfg
!*.ini

# ========================
# 3. ALLOW DIRECTORIES
# ========================
!*/
!.gitignore
!.gitattributes
!.nojekyll

# ========================
# 4. BLOCK SENSITIVE PATTERNS
# ========================
*password*
*secret*
*key*
*token*
*credential*
*.env
.env*
*private*
*internal*
config.local.*
settings.local.*

# ========================
# 5. BLOCK SYSTEM PATHS
# ========================
/etc/
/root/
/boot/
/usr/local/
/proc/
/sys/
/dev/

# ========================
# 6. BLOCK COMMON SENSITIVE FILES
# ========================
secrets.json
credentials.json
config.private.json
private.md
keys.sh
passwords.txt
tokens.yaml

# ========================
# 7. TEMPORARY / GENERATED FILES
# ========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.python-version
*.egg-info/
dist/
build/
*.log
*.tmp
*.temp
.cache/
.tox/
.mypy_cache/
.pytest_cache/
.coverage

# ========================
# 8. SYSTEM / IDE FILES
# ========================
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ========================
# 9. EXPLICIT "PRIVATE" MARKED FILES
# ========================
*_private.*
*.private.*
private-*
*_internal.*

# ========================
# 10. BLOCK HIDDEN FILES (except allowed)
# ========================
.*
!.gitignore
!.gitattributes
!.nojekyll

# ========================
# 11. SPECIFIC FILE ALLOWANCES
# ========================
!README.md
!README.txt
!LICENSE
!LICENSE.txt
!CONTRIBUTING.md
!setup.py
!pyproject.toml
!package.json
!requirements.txt
!environment.yml

# ========================
# 12. DATA / ASSET FILES (blocked)
# ========================
*.csv
*.xlsx
*.xls
*.db
*.sqlite
*.pdf
*.jpg
*.png
*.mp4
*.zip
*.tar
*.gz
